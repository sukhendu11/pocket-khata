# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# JavaScript / JSX
*.js    text eol=lf
*.jsx   text eol=lf
*.cjs   text eol=lf
*.mjs   text eol=lf

# CSS / HTML
*.css   text eol=lf
*.html  text eol=lf

# JSON / YAML / Markdown
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf

# Shell scripts (must stay LF)
*.sh    text eol=lf

# Config files
*.gitignore text eol=lf
*.gitattributes text eol=lf
.eslintrc.cjs text eol=lf

# Binary files (detect as binary, never normalize)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
