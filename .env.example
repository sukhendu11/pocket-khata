# Supabase Analytics Configuration
# Copy this file to .env and fill in your Supabase project details.
# Get these values from: Supabase Dashboard → Settings → API
#
# If these are left as placeholders, analytics will gracefully degrade
# to localStorage-only logging with no remote sync.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
