<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
    </style>

    <!-- Starting window / Splash screen.
         
         Clean native startup: only a solid brand-color background (#E5EAF2)
         while the WebView boots. No custom animated icon, no duplicated
         splash drawable — just the system windowBackground.
         
         On Android 12+ (API 31+): android:windowSplashScreenBackground sets
         the system splash color. Pre-Android 12: android:windowBackground
         provides the same solid color instantly (no decode delay).
         
         After WebView loads → app content renders natively with no
         additional splash layer. -->
    <style name="AppTheme.NoActionBarLaunch" parent="AppTheme.NoActionBar">
        <!-- Android 12+ native system splash: solid brand color only -->
        <item name="android:windowSplashScreenBackground">@color/splashBackground</item>
        <!-- Pre-Android 12 fallback: solid color, zero decoding delay -->
        <item name="android:windowBackground">@color/splashBackground</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>
