<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
    </style>

    <!-- Starting window / Splash screen.
         
         On Android 12+ (API 31+): The native framework attributes below
         customize the mandatory system splash screen to show our branded
         background color (#E5EAF2) + logo icon — no default launcher icon flash.
         
         Pre-Android 12: Falls back to the solid-color windowBackground
         instantly (no bitmap decoding delay).
         
         After splash exits → WebView loads → CSS splash overlay renders
         (logo + animations) → fades into app content. -->
    <style name="AppTheme.NoActionBarLaunch" parent="AppTheme.NoActionBar">
        <!-- Android 12+ native system splash screen customization -->
        <item name="android:windowSplashScreenBackground">@color/splashBackground</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <!-- Pre-Android 12 fallback: solid color, zero decoding delay -->
        <item name="android:windowBackground">@color/splashBackground</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>
